# Jawafdehi Agents configuration

# Base URL for Jawafdehi API write operations.
JAWAFDEHI_API_BASE_URL=https://portal.jawafdehi.org

# Required token for authenticated Jawafdehi API write operations.
# Generate via Jawafdehi API, for example:
# poetry run python manage.py drf_create_token <username>
JAWAFDEHI_API_TOKEN=your_jawafdehi_api_token

# Base URL for Nepal Entity Service.
NES_API_BASE_URL=https://nes.jawafdehi.org

# Maximum number of live news articles to gather per run.
NEWS_ARTICLE_LIMIT=5

# OpenAI-compatible LLM configuration.
# Model name used by agent implementations, for example gpt-5.4.
LLM_MODEL=gpt-5.4

# Required only when an agent implementation uses an OpenAI-compatible provider.
OPENAI_API_KEY=your_openai_compatible_api_key

# Optional custom base URL for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://your-provider.example/v1/
